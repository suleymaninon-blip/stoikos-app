{
  "expo": {
    "name": "Stoikos",
    "slug": "stoikos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "backgroundColor": "#0f0e0b",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1814"
    },
    "scheme": "stoikos",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.stoikos.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1814"
      },
      "package": "com.stoikos.app"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "web": {
      "bundler": "metro",
      "output": "static",
      "baseUrl": "/stoikos-app"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
